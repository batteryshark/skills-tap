#!/bin/sh
set -eu
skill_dir=$(CDPATH= cd -- "$(dirname -- "$0")/.." && pwd)
if [ "${1:-}" = "--help" ] || [ "${1:-}" = "-h" ]; then
  printf '%s\n' 'usage: nano-banana-image --prompt TEXT --output FILE [--input-image FILE] [--resolution 1K|2K|4K] [--model ID]'
  exit 0
fi
if command -v uv >/dev/null 2>&1; then
  exec uv run --script "$skill_dir/scripts/generate_image.py" "$@"
fi
exec python3 "$skill_dir/scripts/generate_image.py" "$@"
